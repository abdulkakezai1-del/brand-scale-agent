    const userMsg = input.trim();
    setInput("");
    setLoading(true);
    const newMessages = [...messages, { role: "user", content: userMsg }];
    setMessages(newMessages);
    const systemWithProfile = buildSystemContext(profile);
    const apiMessages = newMessages.map((m, i) => ({
      role: m.role,
      content: i === 0 && mode ? `MODE: ${mode.id}\n\n${m.content}` : m.content,
    }));
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json",
  "x-api-key": import.meta.env.VITE_ANTHROPIC_KEY,
  "anthropic-version": "2023-06-01"
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: systemWithProfile,
          messages: apiMessages,
        }),
      });
      const data = await res.json();
      const reply = data.content?.find(b => b.type === "text")?.text || "No response.";
      const finalMessages = [...newMessages, { role: "assistant", content: reply }];
      setMessages(finalMessages);
      const newSession = {
        id: Date.now().toString(),
        mode: mode?.id || "FREE",
        modeLabel: mode?.label || "Free Chat",
        modeColor: mode?.color || "#888",
        date: new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
        preview: userMsg.slice(0, 90) + (userMsg.length > 90 ? "..." : ""),
        messages: finalMessages,
      };
      const updated = [newSession, ...sessionHistory].slice(0, 10);
      setSessionHistory(updated);
      saveHistory(updated);
    } catch (e) {
      setMessages(prev => [...prev, { role: "assistant", content: "Error reaching API. Please try again." }]);
    }
    setLoading(false);
  };

  const handleKey = (e) => {
    if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) sendMessage();
  };

