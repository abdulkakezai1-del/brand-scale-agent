function parseMarkdown(text) {
  const lines = text.split("\n");
  const result = [];
  let i = 0;
  while (i < lines.length) {
    const line = lines[i];
    if (line.startsWith("### ")) {
      result.push(<h3 key={i} style={{ color: "#FF4D00", fontSize: "12px", fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", marginTop: "18px", marginBottom: "6px", fontFamily: "'Space Mono', monospace" }}>{line.slice(4)}</h3>);
    } else if (line.startsWith("## ")) {
      result.push(<h2 key={i} style={{ color: "#fff", fontSize: "15px", fontWeight: 700, marginTop: "22px", marginBottom: "8px", borderLeft: "3px solid #FF4D00", paddingLeft: "12px", fontFamily: "'Space Mono', monospace" }}>{line.slice(3)}</h2>);
    } else if (line.startsWith("**") && line.endsWith("**") && !line.slice(2, -2).includes("**")) {
      result.push(<p key={i} style={{ color: "#FFD600", fontWeight: 700, fontSize: "13px", marginBottom: "4px" }}>{line.slice(2, -2)}</p>);
    } else if (line.startsWith("- ") || line.startsWith("• ")) {
      const content = line.slice(2);
      const parts = content.split(/\*\*(.*?)\*\*/g);
      result.push(
        <div key={i} style={{ display: "flex", gap: "8px", marginBottom: "4px", paddingLeft: "4px" }}>
          <span style={{ color: "#FF4D00", flexShrink: 0 }}>›</span>
          <span style={{ color: "#C8C8C8", fontSize: "13px", lineHeight: "1.6" }}>
            {parts.map((p, j) => j % 2 === 1 ? <strong key={j} style={{ color: "#fff" }}>{p}</strong> : p)}
          </span>
        </div>
      );
    } else if (line.match(/^\d+\.\s/)) {
      const content = line.replace(/^\d+\.\s/, "");
      const num = line.match(/^(\d+)/)[1];
      result.push(
        <div key={i} style={{ display: "flex", gap: "10px", marginBottom: "4px" }}>
          <span style={{ color: "#FF4D00", fontFamily: "'Space Mono', monospace", fontSize: "12px", flexShrink: 0, minWidth: "18px" }}>{num}.</span>
          <span style={{ color: "#C8C8C8", fontSize: "13px", lineHeight: "1.6" }}>{content}</span>
        </div>
      );
    } else if (line.startsWith("---")) {
      result.push(<hr key={i} style={{ border: "none", borderTop: "1px solid #1a1a1a", margin: "14px 0" }} />);
    } else if (line.trim()) {
      const parts = line.split(/\*\*(.*?)\*\*/g);
      result.push(
        <p key={i} style={{ color: "#C8C8C8", fontSize: "13px", lineHeight: "1.7", marginBottom: "6px" }}>
          {parts.map((p, j) => j % 2 === 1 ? <strong key={j} style={{ color: "#fff" }}>{p}</strong> : p)}
        </p>
      );
    } else {
      result.push(<div key={i} style={{ height: "5px" }} />);
    }
    i++;
  }
  return result;
}

function buildSystemContext(profile) {
  const filled = PROFILE_FIELDS.filter(f => profile[f.key]?.trim());
  if (!filled.length) return SYSTEM_PROMPT;
  const ctx = filled.map(f => `- ${f.label}: ${profile[f.key]}`).join("\n");
  return `${SYSTEM_PROMPT}\n\nUSER'S BRAND PROFILE (always reference this context in your responses):\n${ctx}`;
}

