      )}

      {/* HISTORY */}
      {phase === "history" && (
        <div style={{ flex: 1, padding: "32px 22px", maxWidth: "740px", width: "100%", margin: "0 auto" }}>
          <div style={{ marginBottom: "26px", display: "flex", alignItems: "flex-start", justifyContent: "space-between" }}>
            <div>
              <div style={{ fontSize: "8px", color: "#FF4D00", letterSpacing: "0.2em", fontFamily: "'Space Mono', monospace", marginBottom: "9px" }}>▲ SESSION HISTORY</div>
              <h2 style={{ fontSize: "20px", fontWeight: 700, fontFamily: "'Space Mono', monospace", marginBottom: "7px" }}>Past Sessions</h2>
              <p style={{ color: "#333", fontSize: "12px" }}>Last 10 sessions saved. Click any to reload the full conversation.</p>
            </div>
            {sessionHistory.length > 0 && (
              <button onClick={async () => { setSessionHistory([]); try { await window.storage.set("session-history", JSON.stringify([])); } catch (_) {} }} style={{ background: "transparent", border: "1px solid #141414", color: "#2a2a2a", padding: "7px 11px", fontSize: "8px", fontFamily: "'Space Mono', monospace", letterSpacing: "0.08em", cursor: "pointer" }}>
                CLEAR ALL
              </button>
            )}
          </div>
          {!historyLoaded && <div style={{ color: "#222", fontSize: "11px", fontFamily: "'Space Mono', monospace" }}>LOADING...</div>}
          {historyLoaded && sessionHistory.length === 0 && (
            <div style={{ padding: "36px", textAlign: "center", border: "1px solid #0f0f0f" }}>
              <div style={{ fontSize: "9px", color: "#222", fontFamily: "'Space Mono', monospace", letterSpacing: "0.1em" }}>NO SESSIONS YET</div>
              <p style={{ color: "#222", fontSize: "11px", marginTop: "7px" }}>Start a conversation and it'll appear here automatically.</p>
            </div>
          )}
          <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
            {sessionHistory.map((session) => (
              <div key={session.id} className="fade-in" style={{ background: "#0b0b0b", border: "1px solid #141414", padding: "14px 16px", display: "flex", alignItems: "center", gap: "14px", transition: "border-color 0.15s", cursor: "pointer" }}
                onMouseEnter={e => e.currentTarget.style.borderColor = "#2a2a2a"}
                onMouseLeave={e => e.currentTarget.style.borderColor = "#141414"}
                onClick={() => loadSession(session)}>
                <div style={{ fontSize: "18px", color: session.modeColor || "#555", flexShrink: 0 }}>
                  {MODES.find(m => m.id === session.mode)?.icon || "◌"}
                </div>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ display: "flex", gap: "10px", alignItems: "center", marginBottom: "4px" }}>
                    <span style={{ fontSize: "8px", fontFamily: "'Space Mono', monospace", color: session.modeColor || "#555", letterSpacing: "0.08em" }}>{session.mode}</span>
                    <span style={{ fontSize: "8px", color: "#2a2a2a", fontFamily: "'Space Mono', monospace" }}>{session.date}</span>
                    <span style={{ fontSize: "8px", color: "#1e1e1e", fontFamily: "'Space Mono', monospace" }}>{session.messages.length} msgs</span>
                  </div>
                  <div style={{ fontSize: "12px", color: "#555", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{session.preview}</div>
                </div>
                <div style={{ display: "flex", gap: "8px", alignItems: "center", flexShrink: 0 }}>
                  <span style={{ fontSize: "9px", color: "#FF4D00", fontFamily: "'Space Mono', monospace" }}>RELOAD →</span>
                  <button onClick={(e) => { e.stopPropagation(); deleteSession(session.id); }} style={{ background: "transparent", border: "none", color: "#222", fontSize: "16px", cursor: "pointer", padding: "0 3px", lineHeight: 1 }}
                    onMouseEnter={e => e.target.style.color = "#aa2222"} onMouseLeave={e => e.target.style.color = "#222"}>×</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* CHAT */}
      {phase === "chat" && (
        <div style={{ flex: 1, display: "flex", flexDirection: "column", maxWidth: "840px", width: "100%", margin: "0 auto", padding: "0 22px" }}>
          {hasProfile && (
            <div style={{ padding: "7px 0", borderBottom: "1px solid #0d0d0d", display: "flex", gap: "14px", overflowX: "auto" }}>
              {PROFILE_FIELDS.filter(f => profile[f.key]?.trim()).slice(0, 5).map(f => (
                <div key={f.key} style={{ display: "flex", gap: "5px", flexShrink: 0, alignItems: "center" }}>
                  <span style={{ fontSize: "7px", color: "#2a2a2a", fontFamily: "'Space Mono', monospace", letterSpacing: "0.08em" }}>{f.label.toUpperCase()}:</span>
                  <span style={{ fontSize: "10px", color: "#555" }}>{profile[f.key]}</span>
                </div>
              ))}
            </div>
          )}
          <div style={{ flex: 1, overflowY: "auto", padding: "22px 0" }}>
            {messages.map((msg, i) => (
              <div key={i} className="fade-in" style={{ marginBottom: "20px", display: "flex", flexDirection: "column", alignItems: msg.role === "user" ? "flex-end" : "flex-start" }}>
                <div style={{ fontSize: "7px", color: "#222", letterSpacing: "0.15em", fontFamily: "'Space Mono', monospace", marginBottom: "5px" }}>
                  {msg.role === "user" ? "YOU" : "▲ BRAND SCALE AI"}
                </div>
                {msg.role === "user" ? (
                  <div style={{ background: "#0d0d0d", border: "1px solid #141414", padding: "11px 15px", maxWidth: "70%", fontSize: "13px", color: "#bbb", lineHeight: "1.6", whiteSpace: "pre-wrap" }}>
                    {msg.content}
                  </div>
                ) : (
                  <div style={{ borderLeft: "2px solid #FF4D00", paddingLeft: "16px", maxWidth: "100%" }}>
                    {parseMarkdown(msg.content)}
                  </div>
                )}
              </div>
            ))}
            {loading && (
              <div className="fade-in" style={{ marginBottom: "20px" }}>
                <div style={{ fontSize: "7px", color: "#222", letterSpacing: "0.15em", fontFamily: "'Space Mono', monospace", marginBottom: "5px" }}>▲ BRAND SCALE AI</div>
                <div style={{ borderLeft: "2px solid #FF4D00", paddingLeft: "16px", display: "flex", alignItems: "center", gap: "6px" }}>
                  <span style={{ color: "#FF4D00", fontFamily: "'Space Mono', monospace", fontSize: "10px", animation: "pulse 1.5s ease-in-out infinite" }}>DIAGNOSING</span>
                  <span style={{ color: "#FF4D00", animation: "blink 1s step-end infinite" }}>▌</span>
                </div>
              </div>
            )}
            <div ref={bottomRef} />
          </div>
          <div style={{ borderTop: "1px solid #0d0d0d", padding: "13px 0 18px", display: "flex", gap: "8px", alignItems: "flex-end" }}>
            <div style={{ flex: 1, background: "#0b0b0b", border: "1px solid #141414", padding: "11px 13px" }}>
              <textarea ref={textareaRef} value={input}
                onChange={e => { setInput(e.target.value); e.target.style.height = "auto"; e.target.style.height = Math.min(e.target.scrollHeight, 130) + "px"; }}
                onKeyDown={handleKey} placeholder="Follow up, add metrics, ask to go deeper..."
                style={{ width: "100%", background: "transparent", border: "none", color: "#ddd", fontSize: "13px", lineHeight: "1.6", outline: "none", height: "38px", fontFamily: "inherit", overflow: "hidden" }} />
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: "4px", alignItems: "flex-end" }}>
              <button onClick={sendMessage} disabled={!input.trim() || loading} style={{ background: input.trim() && !loading ? "#FF4D00" : "#0f0f0f", border: "none", color: input.trim() && !loading ? "#fff" : "#1e1e1e", padding: "11px 17px", fontSize: "16px", transition: "all 0.15s", cursor: input.trim() && !loading ? "pointer" : "default" }}>→</button>
              <div style={{ fontSize: "7px", color: "#111", fontFamily: "'Space Mono', monospace" }}>⌘+↩</div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
